# Onchain wiring — everything is optional. Without these the game runs fully
# offline and keeps bests in localStorage.

# Master switch — set to "true" to enable contract reads/writes.
VITE_USE_CONTRACT=false

# BlocksRun — global leaderboard.
VITE_CONTRACT_ADDRESS=
VITE_DEPLOY_BLOCK=

# BlocksSkin — paid skin shop.
VITE_SKIN_ADDRESS=
VITE_SKIN_DEPLOY_BLOCK=

# BlocksDaily — daily challenge ranking.
VITE_DAILY_ADDRESS=
VITE_DAILY_DEPLOY_BLOCK=

# WalletConnect Cloud project id (optional — a shared default is bundled).
VITE_WC_PROJECT_ID=
